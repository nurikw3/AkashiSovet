BOT_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
SUPERUSER_IDS=123456789,987654321

DATABASE_URL=
# Локально: localhost. В Docker Compose задайте в compose (redis://redis:6379/0), не localhost.
REDIS_URL=redis://localhost:6379/0

# Одноразовый вход в веб-панель (/web в боте): адрес, который открывается в браузере
WEB_PUBLIC_URL=http://localhost:8000
WEB_AUTH_TOKEN_TTL_SECONDS=300
ADMIN_SESSION_MAX_AGE_SECONDS=28800

DB_PATH=./app.db
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
