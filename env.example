# --- Telegram Bot ---
BOT_TOKEN=your_bot_token_here
SUPERUSER_IDS=123456789

# --- LLM (Groq) ---
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-120b

# --- Database (PostgreSQL) ---
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://your:your_postgres_password@postgres:5432/your
GF_DATASOURCE_PASSWORD=your_postgres_password

# --- Cache (Redis) ---
REDIS_URL=redis://redis:6379/0

# --- Web ---
WEB_PUBLIC_URL=http://localhost:8000
WEB_AUTH_TOKEN_TTL_SECONDS=300
ADMIN_SESSION_MAX_AGE_SECONDS=28800
WEB_SESSION_SECRET=your_random_secret_here
WEB_COOKIE_SECURE=false
WEB_LOGIN_RATE_LIMIT=10/minute

# --- Database Pool ---

DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=30

# --- S3 Storage (MinIO) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=your_minio_access_key
S3_SECRET_KEY=your_minio_secret_key
S3_BUCKET_ATTACHMENTS=attachments
S3_BUCKET_PDF=pdf-documents
S3_BUCKET_SIGNATURES=signatures

# --- Observability (Langfuse) ---
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Grafana ---
GRAFANA_PASSWORD=your_grafana_password

# --- Logging ---
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_FILE_LEVEL=INFO
LOG_ERROR_LEVEL=ERROR
LOG_ROTATION_MB=10
LOG_RETENTION_DAYS=7
LOG_ERRORS_ROTATION_MB=5
LOG_ERRORS_RETENTION_DAYS=30
LOG_CLEAN_ON_START=false
LOG_MAX_TOTAL_MB=1024
