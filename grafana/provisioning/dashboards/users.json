                      "spec": {
                        "dataset": "akashi",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  u.full_name,\n  u.position,\n  COUNT(a.id) AS total_applications,\n  ROUND(AVG(EXTRACT(EPOCH FROM (a.t_submit - a.t_start)) / 60), 1) AS avg_prep_min,\n  ROUND(AVG(EXTRACT(EPOCH FROM (a.t_decision - a.t_submit)) / 60), 1) AS avg_review_min,\n  ROUND(AVG(a.reject_count), 2) AS avg_iterations,\n  ROUND(100.0 * COUNT(*) FILTER (WHERE a.reject_count > 0) / NULLIF(COUNT(*), 0), 1) AS reject_rate_pct\nFROM applications a\nJOIN users u ON u.user_id = a.user_id\nWHERE a.t_start IS NOT NULL\n  AND $__timeFilter(a.created_at)\nGROUP BY u.full_name, u.position\nORDER BY total_applications DESC;",
                        "sql": {
